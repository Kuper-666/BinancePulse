<Window x:Class="BinancePulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="BinancePulse" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="▶ Старт" Width="80" Height="30" Click="StartButton_Click" Margin="0,0,5,0"/>
            <Button Content="⏹ Стоп" Width="80" Height="30" Click="StopButton_Click" Margin="0,0,5,0"/>
            <Button Content="📊 Отчёт за день" Width="120" Height="30" Click="ReportButton_Click" Margin="0,0,5,0"/>
            <Button Content="🔄 Проверить обновления" Width="150" Height="30" Click="UpdateButton_Click" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding Status}" Margin="10,5,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding PauseStatus}" Margin="10,5,0,0" Foreground="Yellow" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="Баланс USDC:" Margin="20,5,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Balance}" Margin="5,5,0,0" FontWeight="Bold" Foreground="#2ecc71" VerticalAlignment="Center"/>
            <Separator Width="1" Background="Gray" Margin="15,5"/>
            <TextBlock Text="Версия:" Margin="5,5,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Version}" Margin="3,5,0,0" Foreground="#3498db" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding UpdateStatus}" Margin="10,5,0,0" Foreground="#f39c12" VerticalAlignment="Center"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <!-- Торговля -->
            <TabItem Header="📈 Торговля">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="150"/>
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" ItemsSource="{Binding PairsList}" AutoGenerateColumns="False"
                              CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Пара" Binding="{Binding Pair}" Width="100"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="120"/>
                            <DataGridTextColumn Header="Сигнал" Binding="{Binding Analysis}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBox Grid.Row="1" x:Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Margin="0,5,0,0"
                             FontFamily="Consolas" FontSize="11" Background="#1e1e1e" Foreground="#dcdcdc"/>
                </Grid>
            </TabItem>

            <!-- История сделок -->
            <TabItem Header="📊 История сделок">
                <DataGrid ItemsSource="{Binding TradesHistory}" AutoGenerateColumns="False"
                          CanUserAddRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CloseTime, StringFormat=dd.MM HH:mm}" Width="100"/>
                        <DataGridTextColumn Header="Пара" Binding="{Binding Symbol}" Width="80"/>
                        <DataGridTextColumn Header="Цена входа" Binding="{Binding EntryPrice, StringFormat=F4}" Width="100"/>
                        <DataGridTextColumn Header="Цена выхода" Binding="{Binding ExitPrice, StringFormat=F4}" Width="100"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=F6}" Width="100"/>
                        <DataGridTextColumn Header="PnL USDC" Binding="{Binding PnL, StringFormat=F2}" Width="100"/>
                        <DataGridTextColumn Header="PnL %" Binding="{Binding PnLPercent, StringFormat=F2}" Width="80"/>
                        <DataGridTextColumn Header="Длит." Binding="{Binding Duration, StringFormat=hh\:mm\:ss}" Width="80"/>
                        <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- График баланса -->
            <TabItem Header="📉 График баланса">
                <oxy:PlotView Model="{Binding BalancePlotModel}" Background="#1e1e1e"/>
            </TabItem>

            <!-- Открытые позиции -->
            <TabItem Header="📋 Открытые позиции">
                <DataGrid ItemsSource="{Binding Positions}" AutoGenerateColumns="False"
                          CanUserAddRows="False" HeadersVisibility="Column"
                          Background="#121212" Foreground="White" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Пара" Binding="{Binding Symbol}" Width="80"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=F6}" Width="100"/>
                        <DataGridTextColumn Header="Цена входа" Binding="{Binding EntryPrice, StringFormat=F4}" Width="100"/>
                        <DataGridTextColumn Header="Текущая цена" Binding="{Binding CurrentPrice, StringFormat=F4}" Width="100"/>
                        <DataGridTextColumn Header="PnL USDC" Binding="{Binding PnLDisplay}" Width="100"/>
                        <DataGridTextColumn Header="PnL %" Binding="{Binding PnLPercentDisplay}" Width="80"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding StopLossPrice, StringFormat=F4}" Width="80"/>
                        <DataGridTextColumn Header="TP" Binding="{Binding TakeProfitPrice, StringFormat=F4}" Width="80"/>
                        <DataGridTextColumn Header="Время" Binding="{Binding DurationDisplay}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Бэктест + Оптимизация -->
            <TabItem Header="🧪 Бэктест">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель параметров -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Пара:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Backtest.Symbol}" Width="100" Margin="0,0,10,0"/>
                        <TextBlock Text="С:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <DatePicker SelectedDate="{Binding Backtest.StartDate}" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="По:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <DatePicker SelectedDate="{Binding Backtest.EndDate}" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="SMA:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Backtest.FastSma}" Width="40" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding Backtest.SlowSma}" Width="40" Margin="0,0,10,0"/>
                        <TextBlock Text="RSI:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Backtest.RsiPeriod}" Width="40" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding Backtest.RsiBuy}" Width="40" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding Backtest.RsiSell}" Width="40" Margin="0,0,10,0"/>
                        <TextBlock Text="SL/TP:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Backtest.StopLoss, StringFormat=F2}" Width="50" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding Backtest.TakeProfit, StringFormat=F2}" Width="50" Margin="0,0,10,0"/>
                    </WrapPanel>

                    <!-- Кнопки управления -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                        <Button Content="🚀 Запуск" Width="100" Height="30" Command="{Binding Backtest.RunBacktestCommand}" Margin="0,0,5,0"/>
                        <Button Content="⚡ Оптимизация" Width="120" Height="30" Command="{Binding Backtest.RunOptimizationCommand}" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding Backtest.Status}" Margin="10,5,0,0" Foreground="Yellow" VerticalAlignment="Center"/>
                    </WrapPanel>

                    <!-- Результаты -->
                    <TabControl Grid.Row="2">
                        <TabItem Header="📊 Сводка">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,5">
                                    <Border Background="#2c3e50" Padding="10" Margin="5" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="Доходность" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Backtest.Result.TotalReturnPercent, StringFormat={}{0:F2}%}" Foreground="LimeGreen" FontSize="16"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#2c3e50" Padding="10" Margin="5" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="Win Rate" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Backtest.Result.WinRate, StringFormat={}{0:F1}%}" Foreground="LimeGreen" FontSize="16"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#2c3e50" Padding="10" Margin="5" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="Сделок" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Backtest.Result.TotalTrades}" Foreground="Yellow" FontSize="16"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#2c3e50" Padding="10" Margin="5" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="Max Drawdown" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Backtest.Result.MaxDrawdown, StringFormat={}{0:F1}%}" Foreground="Red" FontSize="16"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#2c3e50" Padding="10" Margin="5" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="Sharpe" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Backtest.Result.SharpeRatio, StringFormat=F2}" Foreground="Cyan" FontSize="16"/>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                                <!-- График equity можно добавить отдельно -->
                            </Grid>
                        </TabItem>

                        <TabItem Header="📋 Сделки">
                            <DataGrid ItemsSource="{Binding Backtest.Trades}" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Вход" Binding="{Binding EntryTime, StringFormat=dd.MM HH:mm}" Width="100"/>
                                    <DataGridTextColumn Header="Выход" Binding="{Binding ExitTime, StringFormat=dd.MM HH:mm}" Width="100"/>
                                    <DataGridTextColumn Header="Цена входа" Binding="{Binding EntryPrice, StringFormat=F4}" Width="100"/>
                                    <DataGridTextColumn Header="Цена выхода" Binding="{Binding ExitPrice, StringFormat=F4}" Width="100"/>
                                    <DataGridTextColumn Header="PnL USDC" Binding="{Binding PnL, StringFormat=F2}" Width="100"/>
                                    <DataGridTextColumn Header="PnL %" Binding="{Binding PnLPercent, StringFormat=F2}" Width="80"/>
                                    <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>