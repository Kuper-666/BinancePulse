<Window x:Class="BinancePulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BinancePulse" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="Старт" Width="80" Height="30" Click="StartButton_Click" Margin="5"/>
            <Button Content="Стоп" Width="80" Height="30" Click="StopButton_Click" Margin="5"/>
            <TextBlock Text="{Binding Status}" Margin="20,5,0,0" FontWeight="Bold"/>
            <TextBlock Text="Баланс: " Margin="20,5,0,0"/>
            <TextBlock Text="{Binding Balance}" Margin="5,5,0,0"/>
        </StackPanel>
        <TextBox Grid.Row="1" x:Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="10"/>
    </Grid>
</Window>